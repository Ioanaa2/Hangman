<Window x:Class="tema2MAP.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:tema2MAP"
        mc:Ignorable="d"
        Title="GameWindow" Height="450" Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- MENIU -->
        <Menu Grid.Row="0" Background="White">
            <MenuItem Header="File">
                <MenuItem Header="New Game"
                          Command="{Binding NewGameCommand}"/>
            </MenuItem>

            <MenuItem Header="Categories">
                <MenuItem Header="All categories"
                          IsCheckable="True"
                          Command="{Binding ChangeCategoryCommand}"
                          CommandParameter="All categories"/>

                <MenuItem Header="Cars"
                          IsCheckable="True"
                          Command="{Binding ChangeCategoryCommand}"
                          CommandParameter="Cars"/>

                <MenuItem Header="Movies"
                          IsCheckable="True"
                          Command="{Binding ChangeCategoryCommand}"
                          CommandParameter="Movies"/>

                <MenuItem Header="States"
                          IsCheckable="True"
                          Command="{Binding ChangeCategoryCommand}"
                          CommandParameter="States"/>

                <MenuItem Header="Mountains"
                          IsCheckable="True"
                          Command="{Binding ChangeCategoryCommand}"
                          CommandParameter="Mountains"/>

                <MenuItem Header="Rivers"
                          IsCheckable="True"
                          Command="{Binding ChangeCategoryCommand}"
                          CommandParameter="Rivers"/>
            </MenuItem>
        </Menu>

        <!-- CONȚINUT -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <TextBlock Text="{Binding PlayerName}"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>

                <TextBlock Text="{Binding SelectedCategory}"
                           FontSize="18"
                           Margin="0,0,0,15"/>

                <Border Background="White" BorderBrush="Black" BorderThickness="3" Height="220">
                    <Grid>
                        <Image Source="{Binding HangmanImage}" Stretch="Uniform"/>
                    </Grid>
                </Border>

                <TextBlock Text="{Binding DisplayWord}"
                           FontSize="24"
                           FontWeight="Bold"
                           Background="Green" Foreground="AliceBlue"
                           Margin="0,30,0,0"/>

                <TextBlock Text="{Binding LivesDisplay}"
                           FontSize="20"
                           Margin="0,10,0,0"/>
            </StackPanel>

            <Grid Grid.Column="1" Margin="30,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- VIEȚI VIZUALE (X BOXES) -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,40">

                    <ItemsControl ItemsSource="{Binding LivesBoxes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="45" Height="45"
                                        Background="LightGray"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        Margin="5"
                                        CornerRadius="5">
                                    <TextBlock Text="{Binding}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="20"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>

                <!-- TASTATURĂ -->
                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="10"
                        Padding="15"
                        VerticalAlignment="Top">

                    <ItemsControl ItemsSource="{Binding Letters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="9"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Letter}"
                                        Command="{Binding DataContext.GuessCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding IsEnabled}"
                                        Margin="3"
                                        Height="35"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
