<Window x:Class="tema2MAP.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:tema2MAP"
        mc:Ignorable="d"
        Title="GameWindow" Height="450" Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="White">
            <MenuItem Header="File">
                <MenuItem Header="New Game"
                          Command="{Binding NewGameCommand}"/>
            </MenuItem>

            <MenuItem Header="Categories">
                <MenuItem Header="All categories"
                          IsCheckable="True"
                          Command="{Binding ChangeCategoryCommand}"
                          CommandParameter="All categories"/>

                <MenuItem Header="Cars"
                          IsCheckable="True"
                          Command="{Binding ChangeCategoryCommand}"
                          CommandParameter="Cars"/>

                <MenuItem Header="Movies"
                          IsCheckable="True"
                          Command="{Binding ChangeCategoryCommand}"
                          CommandParameter="Movies"/>

                <MenuItem Header="States"
                          IsCheckable="True"
                          Command="{Binding ChangeCategoryCommand}"
                          CommandParameter="States"/>

                <MenuItem Header="Mountains"
                          IsCheckable="True"
                          Command="{Binding ChangeCategoryCommand}"
                          CommandParameter="Mountains"/>

                <MenuItem Header="Rivers"
                          IsCheckable="True"
                          Command="{Binding ChangeCategoryCommand}"
                          CommandParameter="Rivers"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- STANGA -->
            <StackPanel Grid.Column="0">

                <TextBlock Text="{Binding PlayerName}"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>

                <TextBlock Text="{Binding SelectedCategory}"
                           FontSize="18"
                           Margin="0,0,0,10"/>

                <TextBlock Text="{Binding TimeLeft, StringFormat='Timp ramas: {0}s'}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="Red"
                           Margin="0,0,0,15"/>

                <Border Background="White"
                        BorderBrush="Black"
                        BorderThickness="3"
                        Height="220">

                    <Canvas Width="200" Height="200">

                        <Line X1="20" Y1="180" X2="180" Y2="180" Stroke="Black" StrokeThickness="4"/>
                        <Line X1="50" Y1="180" X2="50" Y2="20" Stroke="Black" StrokeThickness="4"/>
                        <Line X1="50" Y1="20" X2="140" Y2="20" Stroke="Black" StrokeThickness="4"/>
                        <Line X1="140" Y1="20" X2="140" Y2="40" Stroke="Black" StrokeThickness="3"/>

                        <Ellipse Width="30" Height="30"
                                 Canvas.Left="125" Canvas.Top="40"
                                 Stroke="Black" StrokeThickness="3"
                                 Visibility="{Binding HeadVisibility}"/>

                        <Line X1="140" Y1="70" X2="140" Y2="120"
                              Stroke="Black" StrokeThickness="3"
                              Visibility="{Binding BodyVisibility}"/>

                        <Line X1="140" Y1="85" X2="110" Y2="105"
                              Stroke="Black" StrokeThickness="3"
                              Visibility="{Binding LeftArmVisibility}"/>

                        <Line X1="140" Y1="85" X2="170" Y2="105"
                              Stroke="Black" StrokeThickness="3"
                              Visibility="{Binding RightArmVisibility}"/>

                        <Line X1="140" Y1="120" X2="115" Y2="150"
                              Stroke="Black" StrokeThickness="3"
                              Visibility="{Binding LeftLegVisibility}"/>

                        <Line X1="140" Y1="120" X2="165" Y2="150"
                              Stroke="Black" StrokeThickness="3"
                              Visibility="{Binding RightLegVisibility}"/>

                    </Canvas>
                </Border>

            </StackPanel>

            <!-- DREAPTA -->
            <Grid Grid.Column="1" Margin="30,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- VIEȚI -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,20">

                    <ItemsControl ItemsSource="{Binding LivesBoxes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="45"
                                        Height="45"
                                        Background="LightGray"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        Margin="5"
                                        CornerRadius="5">
                                    <TextBlock Text="{Binding}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="20"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>

                <!-- TASTATURA -->
                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="10"
                        Padding="15">

                    <ItemsControl ItemsSource="{Binding Letters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="9"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Letter}"
                                        Command="{Binding DataContext.GuessCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding IsEnabled}"
                                        Margin="3"
                                        Height="35"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </Border>

                <!-- CUVANT -->
                <Border Grid.Row="2"
                        Background="Black"
                        BorderBrush="Lime"
                        BorderThickness="2"
                        Padding="12"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center">

                    <TextBlock Text="{Binding DisplayWord}"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="Lime"
                               HorizontalAlignment="Center"/>
                </Border>

            </Grid>

        </Grid>
    </Grid>
</Window>
