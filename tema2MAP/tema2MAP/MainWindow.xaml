<Window x:Class="tema2MAP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:tema2MAP"
        Title="MainWindow"
        Height="450" Width="800">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Grid Background="#f7faf0">

        <ListBox ItemsSource="{Binding Users}"
                 SelectedItem="{Binding SelectedUser}"
                 Width="175"
                 Margin="160,89,0,135"
                 HorizontalAlignment="Left"/>

        <Border BorderThickness="3"
                CornerRadius="10"
                Margin="425,89,200,190">
            <Image Source="{Binding CurrentImage}" Stretch="Uniform"/>
        </Border>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="450,234,0,120">

            <Button Content="◀"
                    Command="{Binding PrevCommand}"
                    Width="50" Height="45"/>

            <Button Content="▶"
                    Command="{Binding NextCommand}"
                    Width="50"
                    Margin="20,0,0,0" Height="45"/>
        </StackPanel>

        <Grid Margin="55,314,20,0" Height="105">

            <Button Content="New User"
                    Command="{Binding NewUserCommand}"
                    Width="125"
                    Height="45"
                    Margin="55,30,0,0"
                    HorizontalAlignment="Left"/>

            <Button Content="Delete User"
                    Command="{Binding DeleteUserCommand}"
                    Width="125"
                    Height="45"
                    Margin="205,30,0,0"
                    HorizontalAlignment="Left"/>

            <Button Content="Play"
                    Command="{Binding PlayCommand}"
                    Width="125"
                    Height="45"
                    Margin="355,30,0,0"
                    HorizontalAlignment="Left"/>

            <Button Content="Cancel"
                    Width="125"
                    Height="45"
                    Margin="505,30,0,0"
                    HorizontalAlignment="Left"/>

        </Grid>

    </Grid>
</Window>